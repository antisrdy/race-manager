# Copy this file to .env and fill in the values before running.
#
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# SQLite database path.
# When running with Docker Compose this is inside the named volume.
# For local development the default (race_manager.db in the project root) is fine.
DATABASE=/data/race_manager.db
